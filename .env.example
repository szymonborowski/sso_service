APP_NAME=Laravel
APP_ENV=testing
APP_DEBUG=true
APP_URL=https://sso.microservices.local
APP_DOMAIN=sso.microservices.local

UID=1000
GID=1000

# DB
DB_CONNECTION=mysql
DB_HOST=sso-db
DB_PORT=3306
DB_DATABASE=sso
DB_USERNAME=sso
DB_PASSWORD=
DB_ROOT_PASSWORD=

# PHP
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=50M

# Nginx
NGINX_PORT=80

NETWORK_NAME=web
